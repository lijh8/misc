{
  // vadimcn.vscode-lldb
  // .vscode/tasks.json:
  // open main.cpp in current editor window,
  // F5 (Run / Start Debugging) / Detected Task (compiler: /usr/bin/g++)
  "tasks": [
    {
      "type": "shell",
      "label": "make",
      "command": "/usr/bin/make",
      "args": [],
      "options": {
        // "cwd": "${workspaceFolder}/src",
        "cwd": "${fileDirname}",
      },
      "presentation": {
        "clear": true
      },
    }
  ],
  "version": "2.0.0",
}
