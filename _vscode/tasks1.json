{
  // ms-vscode.cpptools
  // .vscode/tasks.json:
  // open main.cpp in current editor window,
  // F5 (Run / Start Debugging) / Detected Task (compiler: /usr/bin/g++)
  "tasks": [
    {
      "type": "cppbuild",
      "label": "make",
      "command": "make",
      "args": [],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ],
  "version": "2.0.0"
}
